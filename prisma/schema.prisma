// BrandVault data model — Prisma schema for Azure Database for MySQL (8.0).
// Authored from brandvault-mev-build-plan.txt (DATA MODEL section) and CLAUDE.md.
//
// Naming: PascalCase models + camelCase fields in the generated client;
// snake_case tables + columns in the database (via @@map / @map).
//
// Data-model rules honoured (see CLAUDE.md / build plan):
//   - Trademark families are EXPLICIT entities, never inferred from mark_text.
//   - Individual legal rights records are NEVER merged — no unique constraint
//     collapses distinct registrations that happen to share a family.
//   - Minimum required fields for a mark: markText, registryName, status.
//     Everything else is optional so incomplete records are first-class.
//   - Deadlines are derived from the obligation rules in lib/utils.ts and
//     persisted here for alert scheduling; rows are skipped for marks that are
//     missing the dates needed to compute them ("needs data").

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  editor
  viewer
}

// Mirrors the Trademark['status'] union in types/trademark.ts
enum MarkStatus {
  Registered
  Pending
  Published
  Expired
  Abandoned
}

model Company {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  // Nullable: a company can be created by a platform admin during concierge
  // onboarding before the customer's Clerk org exists; linked on their first login.
  clerkOrgId String?  @unique @map("clerk_org_id")
  // Unique local-part for this company's inbound forwarding address
  // (bree-{slug}@<domain>). Nullable until provisioned.
  inboundEmailSlug String? @unique @map("inbound_email_slug")
  createdAt  DateTime @default(now()) @map("created_at")

  users           User[]
  families        TrademarkFamily[]
  trademarks      Trademark[]
  auditLogs       AuditLog[]
  alertPreference AlertPreference?
  inboundEmails   InboundEmail[]
  notifications   Notification[]
  breeQueryLogs   BreeQueryLog[]
  approvals       Approval[]

  @@map("companies")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  role        UserRole @default(viewer)
  companyId   String   @map("company_id")
  clerkUserId String   @unique @map("clerk_user_id")

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  platformAdmin PlatformAdmin?
  notes         Note[]
  auditLogs     AuditLog[]
  notificationReads NotificationRead[]
  breeQueryLogs     BreeQueryLog[]

  @@index([companyId])
  @@map("users")
}

// Cross-tenant access for BrandVault operations (onboarding, data correction,
// support). Separate from the customer admin/editor/viewer roles.
model PlatformAdmin {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("platform_admins")
}

model TrademarkFamily {
  id         String   @id @default(cuid())
  companyId  String   @map("company_id")
  familyName String   @map("family_name")
  createdAt  DateTime @default(now()) @map("created_at")

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  trademarks Trademark[]

  @@index([companyId])
  @@map("trademark_families")
}

model Trademark {
  id        String  @id @default(cuid())
  companyId String  @map("company_id")
  familyId  String? @map("family_id")

  // Minimum required fields
  registryName String     @map("registry_name")
  markText     String     @map("mark_text")
  status       MarkStatus

  // Optional — incomplete records are first-class citizens
  applicationNumber  String?   @map("application_number")
  registrationNumber String?   @map("registration_number")
  filingDate         DateTime? @map("filing_date")
  registrationDate   DateTime? @map("registration_date")
  expiryDate         DateTime? @map("expiry_date")
  publicationDate    DateTime? @map("publication_date")
  clientAgentName    String?   @map("client_agent_name")

  // Lightweight owner/representative fields (plain text — replaces LawPanel's
  // Client/Owner/Representative entity model; populated from imported data).
  ownerName               String? @map("owner_name")
  ownerCountry            String? @map("owner_country")
  representativeName      String? @map("representative_name")
  representativeReference String? @map("representative_reference")

  // Set by the deadline engine when a required date (filing/registration) is
  // missing, so renewal dates can't be computed — surfaced as "needs data".
  needsData Boolean @default(false) @map("needs_data")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  family        TrademarkFamily? @relation(fields: [familyId], references: [id], onDelete: SetNull)
  goodsServices GoodsService[]
  notes         Note[]
  deadlines     Deadline[]
  inboundEmails InboundEmail[]
  notifications Notification[]
  breeQueryLogs BreeQueryLog[]
  approvals     Approval[]

  // company_id is stored on the mark directly (not only via family) so
  // portfolio queries don't need a join. Both FKs indexed.
  @@index([companyId])
  @@index([familyId])
  @@map("trademarks")
}

model GoodsService {
  id          String @id @default(cuid())
  trademarkId String @map("trademark_id")
  classNumber Int    @map("class_number")
  text        String @db.Text

  trademark Trademark @relation(fields: [trademarkId], references: [id], onDelete: Cascade)

  @@index([trademarkId])
  @@map("goods_and_services")
}

model Note {
  id          String   @id @default(cuid())
  trademarkId String   @map("trademark_id")
  userId      String   @map("user_id")
  text        String   @db.Text
  html        String?  @db.Text
  link        String?
  createdAt   DateTime @default(now()) @map("created_at")

  trademark Trademark @relation(fields: [trademarkId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])

  @@index([trademarkId])
  @@index([userId])
  @@map("notes")
}

// Derived from the obligation engine in lib/utils.ts and recalculated on mark
// change. The unique key makes recalculation an idempotent upsert instead of
// duplicating obligations.
model Deadline {
  id           String   @id @default(cuid())
  trademarkId  String   @map("trademark_id")
  type         String
  description  String   @db.Text
  dueDate      DateTime @map("due_date")
  windowStart  DateTime @map("window_start")
  alert180Sent Boolean   @default(false) @map("alert_180_sent")
  alert90Sent  Boolean   @default(false) @map("alert_90_sent")
  alert30Sent  Boolean   @default(false) @map("alert_30_sent")
  // Set when a renewal_confirmation email reports the deadline as satisfied.
  completedAt  DateTime? @map("completed_at")

  trademark Trademark @relation(fields: [trademarkId], references: [id], onDelete: Cascade)

  @@unique([trademarkId, type, dueDate])
  @@index([dueDate])
  @@map("deadlines")
}

model AuditLog {
  id              String   @id @default(cuid())
  companyId       String   @map("company_id")
  userId          String?  @map("user_id")
  isPlatformAdmin Boolean  @default(false) @map("is_platform_admin")
  // Non-human actor for automated actions (e.g. "Bree"). Null = human/user.
  actor           String?
  action          String
  entityType      String   @map("entity_type")
  entityId        String   @map("entity_id")
  // Mandatory for platform-admin edits — enforced in application logic
  // (nullable here because ordinary customer actions don't require it).
  reason          String?  @db.Text
  detailJson      Json?    @map("detail_json")
  createdAt       DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model AlertPreference {
  id             String  @id @default(cuid())
  companyId      String  @unique @map("company_id")
  slackChannelId String? @map("slack_channel_id")
  // Slack install (Bree). Bot token stored unencrypted for MVP — HARDEN LATER.
  slackTeamId    String? @map("slack_team_id")
  slackTeamName  String? @map("slack_team_name")
  slackBotToken  String? @map("slack_bot_token")
  slackEnabled   Boolean @default(false) @map("slack_enabled")
  emailEnabled   Boolean @default(true) @map("email_enabled")
  // Alert thresholds in days. Default [180, 90, 30] is applied in application
  // code — MySQL does not allow a literal DEFAULT on a JSON column.
  thresholdDays  Json    @map("threshold_days")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("alert_preferences")
}

// Phase 4 (Bree inbound). Registry correspondence arriving at a company's
// forwarding address. Step 2 stores it (status=pending); the Step 3 processor
// classifies + acts. Dedup is enforced by (company_id, content_hash).
enum InboundEmailStatus {
  pending
  processed
  needs_review
  unmatched
  dismissed
  // Bree has proposed a mark-mutating action (renewal completion / registration)
  // and is waiting for a human to approve or reject it in Slack.
  awaiting_approval
}

// Propose-and-approve gate for Bree's mark-mutating inbound actions. A HIGH-
// confidence renewal_confirmation or registration_certificate no longer writes
// directly — it creates a pending Approval and posts a Slack Approve/Reject
// message. The write happens only on approval, audited with proposer + approver.
enum ApprovalStatus {
  pending
  approved
  rejected
}

model Approval {
  id             String         @id @default(cuid())
  companyId      String         @map("company_id")
  inboundEmailId String?        @map("inbound_email_id")
  trademarkId    String?        @map("trademark_id")
  // 'renewal_confirmation' | 'registration_certificate'
  actionType     String         @map("action_type")
  summary        String         @db.Text
  // Everything needed to apply the action (deadlineId / fromStatus / refs).
  payloadJson    Json           @map("payload_json")
  status         ApprovalStatus @default(pending)
  proposedBy     String         @default("Bree") @map("proposed_by")
  decidedBySlackId   String?    @map("decided_by_slack_id")
  decidedBySlackName String?    @map("decided_by_slack_name")
  decidedAt      DateTime?      @map("decided_at")
  createdAt      DateTime       @default(now()) @map("created_at")

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  inboundEmail InboundEmail? @relation(fields: [inboundEmailId], references: [id], onDelete: SetNull)
  trademark    Trademark?    @relation(fields: [trademarkId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@map("approvals")
}

model InboundEmail {
  id                 String             @id @default(cuid())
  companyId          String             @map("company_id")
  receivedAt         DateTime           @default(now()) @map("received_at")
  fromAddress        String             @map("from_address")
  subject            String             @db.Text
  bodyText           String             @db.Text @map("body_text")
  rawHeadersJson     Json?              @map("raw_headers_json")
  // dedup signals
  messageId          String?            @map("message_id")
  contentHash        String             @map("content_hash")
  // populated by the Step 3 processor
  classificationJson Json?              @map("classification_json")
  matchedTrademarkId String?            @map("matched_trademark_id")
  status             InboundEmailStatus @default(pending)
  processedAt        DateTime?          @map("processed_at")
  reviewedByUserId   String?            @map("reviewed_by_user_id")
  reviewedAt         DateTime?          @map("reviewed_at")
  // Human correction of Bree's classification (registry/type/matched mark),
  // captured on confirm/correct. Feeds back to the harness corpus as a label.
  reviewClassificationJson Json?        @map("review_classification_json")
  createdAt          DateTime           @default(now()) @map("created_at")

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  matchedTrademark Trademark?        @relation(fields: [matchedTrademarkId], references: [id], onDelete: SetNull)
  attachments      EmailAttachment[]
  approvals        Approval[]

  // Idempotent ingestion: the same content never lands twice for a company.
  @@unique([companyId, contentHash])
  @@index([companyId])
  @@index([status])
  @@map("inbound_emails")
}

model EmailAttachment {
  id             String  @id @default(cuid())
  inboundEmailId String  @map("inbound_email_id")
  filename       String
  mimeType       String  @map("mime_type")
  // Where the binary lives if retained. v1 keeps only extracted text; raw
  // binaries are not persisted to the deployed DB.
  storageRef     String? @map("storage_ref")
  extractedText  String? @db.Text @map("extracted_text")

  inboundEmail InboundEmail @relation(fields: [inboundEmailId], references: [id], onDelete: Cascade)

  @@index([inboundEmailId])
  @@map("email_attachments")
}

// Phase 4b (Bree see-in-app). One row per alert Bree actually sends, so the same
// events surface in the in-app Bree panel. Written by the alert job / status
// change / digest at send time; the deep link is /?notification={id}. The
// Deadline.alert_*_sent flags remain the dedupe mechanism (unchanged).
enum NotificationType {
  renewal_alert
  status_change
  digest
}

enum NotificationChannel {
  slack
  email
}

model Notification {
  id          String              @id @default(cuid())
  companyId   String              @map("company_id")
  trademarkId String?             @map("trademark_id")
  type        NotificationType
  title       String
  body        String              @db.Text
  channel     NotificationChannel
  createdAt   DateTime            @default(now()) @map("created_at")

  company   Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  trademark Trademark?         @relation(fields: [trademarkId], references: [id], onDelete: SetNull)
  reads     NotificationRead[]

  @@index([companyId, createdAt])
  @@map("notifications")
}

// Per-user read state; unread = a company notification with no read for the user.
model NotificationRead {
  id             String   @id @default(cuid())
  notificationId String   @map("notification_id")
  userId         String   @map("user_id")
  readAt         DateTime @default(now()) @map("read_at")

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId])
  @@map("notification_reads")
}

// Phase 4b (Bree see-in-app). One row per WEB free-text query, after the
// intent classifier runs. Includes unsupported results and API-failure
// fallbacks (fallback=true, resolved_intent='unsupported'). Evidence for a
// future Phase 5 (what people actually ask). Slack slash commands are NOT
// logged here — they never pass through the classifier.
model BreeQueryLog {
  id                 String   @id @default(cuid())
  companyId          String   @map("company_id")
  userId             String   @map("user_id")
  inputText          String   @db.Text @map("input_text")
  resolvedIntent     String   @map("resolved_intent")
  matchedTrademarkId String?  @map("matched_trademark_id")
  latencyMs          Int      @map("latency_ms")
  fallback           Boolean  @default(false)
  createdAt          DateTime @default(now()) @map("created_at")

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  trademark Trademark? @relation(fields: [matchedTrademarkId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@map("bree_query_logs")
}
