# Azure Database for MySQL (Flexible Server, MySQL 8.0). SSL is enforced.
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real credentials.
#
#   sslaccept=strict   enforces TLS to Azure (required)
#   connection_limit=5 bounds the pool so Vercel serverless functions don't
#                      exhaust MySQL's connection cap under load
DATABASE_URL="mysql://USER:PASSWORD@HOST.mysql.database.azure.com:3306/brandvault?sslaccept=strict&connection_limit=5"

# Clerk auth — from the Clerk dashboard (API keys). Organizations must be enabled.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Optional (local demo): link the seeded ASOS portfolio to a real Clerk org id
# so signing into that org shows the demo data. Omit for a placeholder link.
SEED_CLERK_ORG_ID=org_xxx

# Slack (Bree) — from the Slack app (api.slack.com/apps). Bot token per company
# is stored in the DB at install; these are the app-level credentials.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
# Public base URL used for the OAuth redirect + Slack request URLs.
NEXT_PUBLIC_APP_URL=https://brandvault-asos.vercel.app

# Phase 4 email classifier (Bree inbound). Local-only for Step 1 (the harness);
# does NOT go to Vercel until the Step 3 processor. Model is overridable.
ANTHROPIC_API_KEY=sk-ant-xxx
EMAIL_CLASSIFIER_MODEL=claude-sonnet-4-6
# Bree web NL intent classifier (fast, interactive). Overridable.
BREE_INTENT_MODEL=claude-haiku-4-5

# Postmark inbound webhook (Phase 4 Step 2). Shared secret presented on the
# webhook URL — set the same value in Postmark (Basic Auth password, ?token=, or
# X-Postmark-Webhook-Token header). The route returns 503 until this is set.
POSTMARK_INBOUND_SECRET=

# Testing fallback: Postmark's hash address (…@inbound.postmarkapp.com) is not a
# bree-{slug} address, so it won't resolve to a company. Set this to a company's
# canonical slug to route any UNRESOLVED inbound email to that test company.
# Leave UNSET in real multi-tenant use so mail only reaches the addressed company.
INBOUND_FALLBACK_COMPANY_SLUG=
